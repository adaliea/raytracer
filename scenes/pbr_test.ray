# A scene to test PBR materials and displacement mapping

Background {
    color 0.1 0.1 0.1
}

Camera {
    eye -4 2 8
    lookAt 0 0 0
    up 0 1 0
    fovy 25
}

Lights {
    Light {
        position -20 3 -10
        color 30 30 30
    }
}

Materials {
    # Cobblestone material for the ground plane
    Material {
        textureFilename textures/rocky_terrain/rocky_terrain_diff_2k.jpg
        displacementMapFilename textures/rocky_terrain/rocky_terrain_disp_2k.png
        normalMapFilename textures/rocky_terrain/rocky_terrain_nor_gl_2k.exr
        displacementStrength 0.3
        diffuseColor 1 1 1
        maxEdgeLength 0.1
    }
    
    # Whitewashed brick for the cylinder
    Material {
        textureFilename textures/whitewashed_brick/whitewashed_brick_diff_2k.jpg
        displacementMapFilename textures/whitewashed_brick/whitewashed_brick_disp_2k.png
        normalMapFilename textures/whitewashed_brick/whitewashed_brick_nor_gl_2k.exr
        displacementStrength 0.1
        shininess 20
        subdivisionLevel 4
    }
}

Group {
    # Ground plane (as two triangles)
    Triangle {
        vertex0 -10 0 10
        vertex1 10 0 10
        vertex2 -10 0 -10
        tex_xy_0 0 4
        tex_xy_1 4 4
        tex_xy_2 0 0
        materialIndex 0
    }
    Triangle {
        vertex0 10 0 -10
        vertex1 -10 0 -10
        vertex2 10 0 10
        tex_xy_0 4 0
        tex_xy_1 0 0
        tex_xy_2 4 4
        materialIndex 0
    }
    
    # Cylinder
    Cylinder {
        center 0 1 0
        radius 1
        height 2
        materialIndex 1
    }
}